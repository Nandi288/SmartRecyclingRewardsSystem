@model List<SmartRecyclingRewardsSystem.Models.MaterialType>

@{
    ViewBag.Title = "Manage Materials";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <style>
        .page-wrap {
            max-width: 1100px;
            margin: 0 auto;
            padding: 32px 20px 60px;
        }

        .page-header-simple {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 12px;
        }

            .page-header-simple h1 {
                font-family: 'Syne',sans-serif;
                font-size: 26px;
                font-weight: 700;
                color: var(--green-deep);
                margin: 0;
            }

            .page-header-simple p {
                color: var(--text-muted);
                font-size: 14px;
                margin: 4px 0 0 0;
            }

        .btn-new {
            background: var(--green-mid);
            color: #fff;
            border: none;
            border-radius: 9px;
            padding: 11px 24px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-new:hover {
                background: #245c42;
                color: #fff;
            }

        .section-card {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.07);
            border-radius: 12px;
            overflow: hidden;
        }

        .table-srr {
            width: 100%;
            border-collapse: collapse;
        }

            .table-srr th {
                background: #f8fdf9;
                font-size: 11px;
                font-weight: 700;
                color: var(--text-muted);
                text-transform: uppercase;
                padding: 12px 16px;
                text-align: left;
                border-bottom: 1px solid #f0f0f0;
            }

            .table-srr td {
                padding: 12px 16px;
                font-size: 13px;
                border-bottom: 1px solid #f7f7f7;
                vertical-align: middle;
            }

            .table-srr tr:last-child td {
                border-bottom: none;
            }

        .badge-active {
            background: #dcfce7;
            color: #166534;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-inactive {
            background: #fee2e2;
            color: #991b1b;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .btn-action {
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            margin-right: 4px;
        }

        .btn-edit {
            background: #dbeafe;
            color: #1e40af;
        }

            .btn-edit:hover {
                background: #bfdbfe;
                color: #1e40af;
            }

        .btn-delete {
            background: #fee2e2;
            color: #991b1b;
        }

            .btn-delete:hover {
                background: #fecaca;
                color: #991b1b;
            }

        .color-dot {
            display: inline-block;
            width: 16px;
            height: 16px;
            border-radius: 4px;
            border: 1px solid #ddd;
        }
    </style>
}

<div class="page-wrap">
    <div class="page-header-simple">
        <div>
            <h1>Manage Materials</h1>
            <p>Add, edit, or deactivate material types and their point values.</p>
        </div>
        <a href="@Url.Action("Create")" class="btn-new"><i class="fa fa-plus"></i> Add New Material</a>
    </div>

    <div class="section-card">
        <table class="table-srr">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Points/Kg</th>
                    <th>CO₂ Saving/Kg</th>
                    <th>Colour</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td><strong>@m.Name</strong></td>
                        <td>@m.Description</td>
                        <td>@m.PointsPerKg</td>
                        <td>@m.CO2SavingPerKg</td>
                        <td><span class="color-dot" style="background:@m.ColourCode;"></span></td>
                        <td>
                            @if (m.IsActive)
                            {
                                <span class="badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge-inactive">Inactive</span>
                            }
                        </td>
                        <td>
                            <a href="@Url.Action("Edit", new { id = m.MaterialTypeId })" class="btn-action btn-edit"><i class="fa fa-pen"></i> Edit</a>
                            <a href="@Url.Action("Delete", new { id = m.MaterialTypeId })" class="btn-action btn-delete"><i class="fa fa-trash"></i> Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>