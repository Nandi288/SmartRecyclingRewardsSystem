@model IEnumerable<SmartRecyclingRewardsSystem.Models.Reward>
@{
    ViewBag.Title = "Rewards";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var resident = ViewBag.Resident as SmartRecyclingRewardsSystem.Models.ApplicationUser;
    int balance = ViewBag.PointsBalance;

    // Maps a reward name to a Font Awesome icon + accent color, since we don't
    // have real product photos yet. Falls back to a generic gift icon.
    Func<string, string> getIcon = (name) =>
    {
        var n = name.ToLower();
        if (n.Contains("airtime")) return "fa-mobile-screen";
        if (n.Contains("voucher") && (n.Contains("woolworths") || n.Contains("checkers"))) return "fa-basket-shopping";
        if (n.Contains("uber") || n.Contains("eats")) return "fa-utensils";
        if (n.Contains("bag") || n.Contains("tote")) return "fa-bag-shopping";
        if (n.Contains("bottle")) return "fa-bottle-water";
        if (n.Contains("compost")) return "fa-seedling";
        if (n.Contains("tree")) return "fa-tree";
        return "fa-gift";
    };
}

@section styles {
    <style>
        .rewards-wrap {
            max-width: 1100px;
            margin: 0 auto;
            padding: 32px 20px 60px;
        }

        .rewards-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 28px;
        }

            .rewards-head h1 {
                font-family: 'Syne', sans-serif;
                font-size: 24px;
                font-weight: 700;
                color: var(--green-deep);
                margin: 0 0 4px;
            }

            .rewards-head p {
                color: var(--text-muted);
                font-size: 14px;
                margin: 0;
            }

        .balance-pill {
            background: var(--green-deep);
            border-radius: 12px;
            padding: 12px 24px;
            text-align: right;
        }

            .balance-pill .label {
                font-size: 11px;
                color: rgba(255,255,255,0.5);
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .balance-pill .num {
                font-family: 'Syne', sans-serif;
                font-size: 26px;
                font-weight: 800;
                color: var(--lime);
                line-height: 1.2;
            }

        .rewards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 18px;
        }

        .reward-card {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.07);
            border-radius: 14px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            transition: transform 0.15s, box-shadow 0.15s;
        }

            .reward-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.06);
            }

            .reward-card.locked {
                opacity: 0.75;
            }

        .reward-icon {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            background: rgba(45, 106, 79, 0.1);
            color: var(--green-mid);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            margin-bottom: 14px;
        }

        .reward-card.locked .reward-icon {
            background: #f1f1f1;
            color: var(--text-muted);
        }

        .reward-name {
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 4px;
        }

        .reward-desc {
            font-size: 13px;
            color: var(--text-muted);
            flex-grow: 1;
            margin-bottom: 14px;
            line-height: 1.4;
        }

        .reward-cost {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(183, 224, 74, 0.18);
            color: #4d6b1f;
            font-size: 12px;
            font-weight: 700;
            padding: 4px 11px;
            border-radius: 20px;
            width: fit-content;
            margin-bottom: 14px;
        }

        .reward-card.locked .reward-cost {
            background: #f1f1f1;
            color: var(--text-muted);
        }

        .btn-redeem {
            background: var(--green-mid);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
        }

            .btn-redeem:hover {
                background: #245c42;
            }

        .btn-locked {
            background: #f1f1f1;
            color: var(--text-muted);
            border: none;
            border-radius: 8px;
            padding: 10px;
            font-size: 12px;
            font-weight: 600;
            width: 100%;
            cursor: not-allowed;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

            .empty-state i {
                font-size: 40px;
                color: var(--green-bright);
                margin-bottom: 12px;
                display: block;
            }
    </style>
}

<div class="rewards-wrap">

    <div class="rewards-head">
        <div>
            <h1><i class="fa fa-gift"></i> Rewards Catalogue</h1>
            <p>Redeem your points for real-world rewards.</p>
        </div>
        <div class="balance-pill">
            <div class="label">Your Balance</div>
            <div class="num">@balance pts</div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="flash-bar flash-success" style="border-radius:8px;margin-bottom:20px;">
            <i class="fa fa-circle-check"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="flash-bar flash-error" style="border-radius:8px;margin-bottom:20px;">
            <i class="fa fa-circle-exclamation"></i> @TempData["Error"]
        </div>
    }

    @if (Model.Any())
    {
        <div class="rewards-grid">
            @foreach (var reward in Model)
            {
                bool canAfford = balance >= reward.PointsCost;
                var icon = getIcon(reward.Name);

                <div class="reward-card @(canAfford ? "" : "locked")">
                    <div class="reward-icon"><i class="fa @icon"></i></div>
                    <div class="reward-name">@reward.Name</div>
                    <div class="reward-desc">@reward.Description</div>
                    <div class="reward-cost"><i class="fa fa-leaf fa-xs"></i> @reward.PointsCost pts</div>

                    @using (Html.BeginForm("Redeem", "Rewards", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@reward.RewardId" />

                        if (canAfford)
                        {
                            <button type="submit" class="btn-redeem"
                                    onclick="return confirm('Redeem &quot;@reward.Name&quot; for @reward.PointsCost points?');">
                                Redeem
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn-locked" disabled>
                                Need @(reward.PointsCost - balance) more pts
                            </button>
                        }
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fa fa-gift"></i>
            <strong>No rewards are available right now.</strong>
            <p style="margin-top:8px;">Check back soon!</p>
        </div>
    }

</div>