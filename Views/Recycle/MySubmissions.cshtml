@using SmartRecyclingRewardsSystem.Models
@model List<SmartRecyclingRewardsSystem.Models.RecyclingSubmission>

@{
    ViewBag.Title = "My Submissions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 style="padding:20px;font-family:'Syne',sans-serif;">My Submissions</h2>

<div style="padding:0 20px 40px 20px;">

    <a href="/Recycle/Log" style="background:#2d6a4f;color:#fff;border:none;border-radius:8px;padding:10px 20px;font-size:14px;font-weight:600;text-decoration:none;display:inline-block;margin-bottom:20px;">
        <i class="fa fa-plus"></i> Log New Recycling
    </a>

    <div style="background:#fff;border-radius:12px;border:1px solid #eee;overflow:auto;">

        @if (Model != null && Model.Count > 0)
        {
            <table style="width:100%;border-collapse:collapse;font-size:14px;">
                <thead>
                    <tr style="background:#f8fdf9;">
                        <th style="padding:12px 16px;text-align:left;">Date</th>
                        <th style="padding:12px 16px;text-align:left;">Material</th>
                        <th style="padding:12px 16px;text-align:left;">Weight</th>
                        <th style="padding:12px 16px;text-align:left;">Drop-Off Point</th>
                        <th style="padding:12px 16px;text-align:left;">Status</th>
                        <th style="padding:12px 16px;text-align:left;">Points</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:12px 16px;">@s.SubmissionDate.ToString("dd MMM yyyy")</td>
                            <td style="padding:12px 16px;">@s.MaterialType.Name</td>
                            <td style="padding:12px 16px;">@s.WeightKg kg</td>
                            <td style="padding:12px 16px;">@s.DropOffPoint.Name</td>
                            <td style="padding:12px 16px;">
                                @if (s.Status == SubmissionStatus.Pending)
                                {
                                    <span style="background:#fef9c3;color:#854d0e;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;">Pending</span>
                                }
                                else if (s.Status == SubmissionStatus.Verified)
                                {
                                    <span style="background:#dcfce7;color:#166534;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;">Verified</span>
                                }
                                else
                                {
                                    <span style="background:#fee2e2;color:#991b1b;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;">Rejected</span>
                                }
                            </td>
                            <td style="padding:12px 16px;">
                                @if (s.PointsAwarded > 0)
                                {
                                    <span style="color:#2d6a4f;font-weight:700;">+@s.PointsAwarded</span>
                                }
                                else
                                {
                                    <span style="color:#6b7c6e;">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div style="text-align:center;padding:60px 20px;color:#6b7c6e;">
                <i class="fa fa-recycle" style="font-size:36px;display:block;margin-bottom:12px;color:#74c69d;"></i>
                <h3 style="color:#111c16;">No submissions yet</h3>
                <p>Start earning points by logging your first recycling activity.</p>
                <a href="/Recycle/Log" style="color:#2d6a4f;font-weight:600;text-decoration:none;">Log your first submission →</a>
            </div>
        }

    </div>

</div>