@model SmartRecyclingRewardsSystem.Models.ApplicationUser

@{
    ViewBag.Title = "Delete User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <style>
        .page-wrap {
            max-width: 640px;
            margin: 0 auto;
            padding: 32px 20px 60px;
        }

        .page-header-simple {
            margin-bottom: 28px;
        }

            .page-header-simple h1 {
                font-family: 'Syne',sans-serif;
                font-size: 26px;
                font-weight: 700;
                color: var(--green-deep);
            }

            .page-header-simple p {
                color: var(--text-muted);
                font-size: 14px;
                margin-top: 4px;
            }

        .confirm-card {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.07);
            border-radius: 12px;
            padding: 32px;
            text-align: center;
        }

        .confirm-icon {
            font-size: 48px;
            color: #ef4444;
            margin-bottom: 16px;
        }

        .confirm-card h2 {
            font-family: 'Syne',sans-serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--text-dark);
        }

        .detail-box {
            background: #f8fdf9;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 24px;
            text-align: left;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px solid #f0f0f0;
            font-size: 13px;
        }

            .detail-row:last-child {
                border-bottom: none;
            }

        .detail-label {
            color: var(--text-muted);
            font-weight: 500;
        }

        .detail-value {
            color: var(--text-dark);
            font-weight: 600;
        }

        .btn-danger {
            background: #ef4444;
            color: #fff;
            border: none;
            border-radius: 9px;
            padding: 13px 32px;
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 9px;
        }

            .btn-danger:hover {
                background: #dc2626;
            }

        .btn-cancel {
            background: transparent;
            color: var(--text-muted);
            border: 1.5px solid #d1d9d4;
            border-radius: 9px;
            padding: 13px 28px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 9px;
        }

            .btn-cancel:hover {
                background: #f5f5f5;
                border-color: #b0b0b0;
                text-decoration: none;
                color: var(--text-muted);
            }

        .form-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-top: 8px;
        }

        .warning-box {
            background: #fef9c3;
            border: 1px solid #fde68a;
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 20px;
            font-size: 13px;
            color: #854d0e;
        }
    </style>
}

<div class="page-wrap">
    <div class="page-header-simple">
        <h1>Delete User</h1>
        <p>Are you sure you want to delete this user?</p>
    </div>

    <div class="confirm-card">
        <div class="confirm-icon"><i class="fa fa-triangle-exclamation"></i></div>
        <h2>Delete @Model.FullName?</h2>

        @* Explains the fallback behaviour so it's not a surprise to the admin *@
        <div class="warning-box">
            This action cannot be undone. If this user has any recycling submissions, points history, or event
            registrations, they will be <strong>deactivated</strong> instead of deleted, so that historical records
            aren't broken.
        </div>

        <div class="detail-box">
            <div class="detail-row">
                <span class="detail-label">Name</span>
                <span class="detail-value">@Model.FullName</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Email</span>
                <span class="detail-value">@Model.Email</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Role</span>
                <span class="detail-value">@Model.Role</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Status</span>
                <span class="detail-value">@(Model.IsActive ? "Active" : "Inactive")</span>
            </div>
        </div>

        @* Posts to the Delete action in UserManagementController *@
        @using (Html.BeginForm("Delete", "UserManagement", new { id = Model.Id }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="form-actions">
                <button type="submit" class="btn-danger"><i class="fa fa-trash"></i> Delete</button>
                <a href="@Url.Action("Index")" class="btn-cancel"><i class="fa fa-xmark"></i> Cancel</a>
            </div>
        }
    </div>
</div>