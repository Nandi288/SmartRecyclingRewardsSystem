@model List<SmartRecyclingRewardsSystem.Models.DropOffPoint>
@{
    ViewBag.Title = "Drop-Off Locations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
<style>
    .page-wrap { max-width:1000px; margin:0 auto; padding:32px 20px 60px; }

    .page-banner {
        background: linear-gradient(135deg, #1a3a2a 0%, #2d6a4f 100%);
        border-radius:14px; padding:28px 32px; margin-bottom:28px;
        display:flex; align-items:center; gap:16px;
    }
    .page-banner-icon { width:52px; height:52px; background:rgba(183,224,74,0.2); border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:24px; color:#b7e04a; flex-shrink:0; }
    .page-banner h1 { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; color:#fff; margin:0 0 4px; }
    .page-banner p  { color:rgba(255,255,255,0.6); font-size:13px; margin:0; }

    .locations-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:16px; }

    .loc-card { background:#fff; border:1px solid rgba(0,0,0,0.07); border-radius:12px; overflow:hidden; transition:box-shadow 0.2s; }
    .loc-card:hover { box-shadow:0 4px 20px rgba(26,58,42,0.1); }

    .loc-card-head { background:#f8fdf9; padding:16px 20px; border-bottom:1px solid #f0f0f0; display:flex; align-items:flex-start; gap:12px; }
    .loc-icon { width:38px; height:38px; background:#edf7f1; border-radius:9px; display:flex; align-items:center; justify-content:center; font-size:16px; color:var(--green-mid); flex-shrink:0; margin-top:2px; }
    .loc-name { font-family:'Syne',sans-serif; font-size:14px; font-weight:700; color:var(--green-deep); line-height:1.3; }
    .loc-city { font-size:12px; color:var(--text-muted); margin-top:3px; }

    .loc-card-body { padding:14px 20px; }
    .loc-row { display:flex; align-items:flex-start; gap:10px; margin-bottom:10px; }
    .loc-row:last-child { margin-bottom:0; }
    .loc-row-icon { color:var(--green-mid); font-size:12px; margin-top:2px; flex-shrink:0; width:16px; text-align:center; }
    .loc-row-text { font-size:13px; color:var(--text-dark); line-height:1.4; }
    .loc-row-label { font-size:11px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:2px; }

    .officer-chip { display:inline-flex; align-items:center; gap:5px; background:#edf7f1; color:var(--green-mid); padding:3px 10px; border-radius:20px; font-size:11px; font-weight:600; }

    .empty-state { text-align:center; padding:60px 20px; background:#fff; border:1px solid rgba(0,0,0,0.07); border-radius:12px; color:var(--text-muted); }
    .empty-state i { font-size:40px; color:var(--green-bright); margin-bottom:12px; display:block; }

    @@media(max-width:480px) { .locations-grid { grid-template-columns:1fr; } }
</style>
}

<div class="page-wrap">

    <div class="page-banner">
        <div class="page-banner-icon"><i class="fa fa-location-dot"></i></div>
        <div>
            <h1>Drop-Off Locations</h1>
            <p>Find a recycling drop-off point near you — eThekwini, KwaZulu-Natal</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fa fa-location-dot"></i>
            <strong>No drop-off points available yet.</strong>
            <p style="margin-top:8px;">Check back soon — the administrator is setting up locations.</p>
        </div>
    }
    else
    {
        <div class="locations-grid">
            @foreach (var p in Model)
            {
                <div class="loc-card">
                    <div class="loc-card-head">
                        <div class="loc-icon"><i class="fa fa-recycle"></i></div>
                        <div>
                            <div class="loc-name">@p.Name</div>
                            <div class="loc-city"><i class="fa fa-city fa-xs"></i> @p.City</div>
                        </div>
                    </div>
                    <div class="loc-card-body">
                        <div class="loc-row">
                            <div class="loc-row-icon"><i class="fa fa-map-pin"></i></div>
                            <div>
                                <div class="loc-row-label">Address</div>
                                <div class="loc-row-text">@p.Address</div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(p.OperatingHours))
                        {
                            <div class="loc-row">
                                <div class="loc-row-icon"><i class="fa fa-clock"></i></div>
                                <div>
                                    <div class="loc-row-label">Operating Hours</div>
                                    <div class="loc-row-text">@p.OperatingHours</div>
                                </div>
                            </div>
                        }
                        @if (p.AssignedOfficer != null)
                        {
                            <div class="loc-row">
                                <div class="loc-row-icon"><i class="fa fa-shield-halved"></i></div>
                                <div>
                                    <div class="loc-row-label">Collection Officer</div>
                                    <span class="officer-chip">
                                        <i class="fa fa-user fa-xs"></i>
                                        @p.AssignedOfficer.FullName
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
