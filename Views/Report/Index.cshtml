@model SmartRecyclingRewardsSystem.Controllers.CommunityReportViewModel
@{
    ViewBag.Title = "Community Recycling Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var matLabels = Model.ByMaterial.Select(x => x.MaterialName).ToList();
    var matWeights = Model.ByMaterial.Select(x => x.TotalWeightKg).ToList();
    var matColours = Model.ByMaterial.Select(x => x.ColourCode).ToList();

    string matLabelsJson = Newtonsoft.Json.JsonConvert.SerializeObject(matLabels);
    string matWeightsJson = Newtonsoft.Json.JsonConvert.SerializeObject(matWeights);
    string matColoursJson = Newtonsoft.Json.JsonConvert.SerializeObject(matColours);
}

@section styles {
    <style>
        .report-wrap {
            max-width: 1100px;
            margin: 0 auto;
            padding: 32px 20px 60px;
        }

        .page-banner {
            background: linear-gradient(135deg,#1a3a2a 0%,#2d6a4f 100%);
            border-radius: 14px;
            padding: 32px 36px;
            margin-bottom: 28px;
        }

            .page-banner h1 {
                font-family: 'Syne',sans-serif;
                font-size: 26px;
                font-weight: 800;
                color: #fff;
                margin-bottom: 4px;
            }

            .page-banner p {
                color: rgba(255,255,255,0.6);
                font-size: 14px;
                margin: 0;
            }

        .filter-card {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.07);
            border-radius: 12px;
            padding: 20px 24px;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
        }

            .filter-card label {
                font-size: 13px;
                font-weight: 600;
                color: #1a3a2a;
            }

        .filter-select {
            padding: 9px 14px;
            border: 1.5px solid #d1d9d4;
            border-radius: 8px;
            font-size: 14px;
            font-family: 'Inter',sans-serif;
            color: #111c16;
            outline: none;
            background: #fff;
        }

            .filter-select:focus {
                border-color: #2d6a4f;
                box-shadow: 0 0 0 3px rgba(45,106,79,0.1);
            }

        .btn-filter {
            background: #2d6a4f;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 22px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s;
        }

            .btn-filter:hover {
                background: #245c42;
            }

        .export-row {
            display: flex;
            gap: 10px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .btn-pdf {
            background: #ef4444;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s;
        }

            .btn-pdf:hover {
                background: #dc2626;
                color: #fff;
            }

        .btn-excel {
            background: #16a34a;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s;
        }

            .btn-excel:hover {
                background: #15803d;
                color: #fff;
            }

        .stats-row {
            display: grid;
            grid-template-columns: repeat(5,1fr);
            gap: 14px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.07);
            border-radius: 12px;
            padding: 18px 16px;
            text-align: center;
        }

        .stat-label {
            font-size: 11px;
            font-weight: 600;
            color: #6b7c6e;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .stat-value {
            font-family: 'Syne',sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: #1a3a2a;
            line-height: 1;
        }

        .equiv-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }

        .equiv-card {
            background: #1a3a2a;
            border-radius: 12px;
            padding: 20px 24px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .equiv-icon {
            font-size: 28px;
            flex-shrink: 0;
        }

        .equiv-num {
            font-family: 'Syne',sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: #b7e04a;
            line-height: 1;
        }

        .equiv-desc {
            font-size: 12px;
            color: rgba(255,255,255,0.6);
            margin-top: 3px;
        }

        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }

        .section-card {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.07);
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .section-head {
            padding: 16px 20px;
            border-bottom: 1px solid #f0f0f0;
        }

            .section-head h2 {
                font-family: 'Syne',sans-serif;
                font-size: 15px;
                font-weight: 700;
                color: #1a3a2a;
                margin: 0;
            }

        .chart-wrap {
            padding: 20px;
        }

        .rep-table {
            width: 100%;
            border-collapse: collapse;
        }

            .rep-table th {
                background: #f8fdf9;
                font-size: 11px;
                font-weight: 700;
                color: #6b7c6e;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                padding: 10px 16px;
                text-align: left;
                border-bottom: 1px solid #f0f0f0;
            }

            .rep-table td {
                padding: 12px 16px;
                font-size: 13px;
                color: #111c16;
                border-bottom: 1px solid #f7f7f7;
            }

            .rep-table tr:last-child td {
                border-bottom: none;
            }

        .mat-dot {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 8px;
        }

        .empty-state {
            text-align: center;
            padding: 48px 16px;
            color: #6b7c6e;
        }

            .empty-state i {
                font-size: 40px;
                color: #74c69d;
                margin-bottom: 12px;
                display: block;
            }

        @@media(max-width:900px) {
            .stats-row {
                grid-template-columns: repeat(3,1fr);
            }

            .charts-row, .equiv-row {
                grid-template-columns: 1fr;
            }
        }

        @@media(max-width:480px) {
            .stats-row {
                grid-template-columns: repeat(2,1fr);
            }
        }
    </style>
}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<div class="report-wrap">

    <div class="page-banner">
        <h1><i class="fa fa-file-lines"></i> Community Recycling Report</h1>
        <p>Monthly recycling totals, environmental impact, and top performers — eThekwini, KZN</p>
    </div>

    @* ── Filter form ──────────────────────────────────────────── *@
    @using (Html.BeginForm("Index", "Report", FormMethod.Get))
    {
        <div class="filter-card">
            <label>Select Month:</label>
            @Html.DropDownList("month", ViewBag.Months as IEnumerable<SelectListItem>, new { @class = "filter-select" })

            <label>Year:</label>
            @Html.DropDownList("year", ViewBag.Years as IEnumerable<SelectListItem>, new { @class = "filter-select" })

            <button type="submit" class="btn-filter">
                <i class="fa fa-magnifying-glass"></i> Generate Report
            </button>
        </div>
    }

    @* ── Export buttons ───────────────────────────────────────── *@
    <div class="export-row">
        <a href="@Url.Action("ExportPdf","Report", new { month = Model.Month, year = Model.Year })"
           class="btn-pdf">
            <i class="fa fa-file-pdf"></i> Export to PDF
        </a>
        <a href="@Url.Action("ExportExcel","Report", new { month = Model.Month, year = Model.Year })"
           class="btn-excel">
            <i class="fa fa-file-excel"></i> Export to Excel
        </a>
    </div>

    @if (Model.TotalSubmissions == 0)
    {
        <div class="section-card">
            <div class="empty-state">
                <i class="fa fa-calendar-xmark"></i>
                <strong>No verified submissions found for @Model.MonthLabel.</strong>
                <p style="margin-top:8px;">Try selecting a different month or wait for Collection Officers to verify pending submissions.</p>
            </div>
        </div>
    }
    else
    {
        @* ── Summary stat cards ────────────────────────────────── *@
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-label">Total Weight</div>
                <div class="stat-value">@Model.TotalWeightKg.ToString("0.#") <small style="font-size:12px">kg</small></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">CO₂ Saved</div>
                <div class="stat-value">@Model.TotalCo2Kg.ToString("0.##") <small style="font-size:12px">kg</small></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Points Awarded</div>
                <div class="stat-value">@Model.TotalPoints.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Submissions</div>
                <div class="stat-value">@Model.TotalSubmissions</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Residents</div>
                <div class="stat-value">@Model.UniqueResidents</div>
            </div>
        </div>

        @* ── CO2 Equivalents ─────────────────────────────────────── *@
        <div class="equiv-row">
            <div class="equiv-card">
                <span class="equiv-icon">🚗</span>
                <div>
                    <div class="equiv-num">@Model.CarKmEquivalent km</div>
                    <div class="equiv-desc">equivalent driving distance saved</div>
                </div>
            </div>
            <div class="equiv-card">
                <span class="equiv-icon">🌳</span>
                <div>
                    <div class="equiv-num">@Model.TreesEquivalent trees</div>
                    <div class="equiv-desc">equivalent trees absorbing CO₂ for a year</div>
                </div>
            </div>
        </div>

        @* ── Charts ──────────────────────────────────────────────── *@
        <div class="charts-row">
            <div class="section-card">
                <div class="section-head">
                    <h2><i class="fa fa-chart-pie fa-sm"></i> Weight by Material Type</h2>
                </div>
                <div class="chart-wrap">
                    <canvas id="matChart" height="220"></canvas>
                </div>
            </div>
            <div class="section-card">
                <div class="section-head">
                    <h2><i class="fa fa-chart-bar fa-sm"></i> Points by Material</h2>
                </div>
                <div class="chart-wrap">
                    <canvas id="ptsChart" height="220"></canvas>
                </div>
            </div>
        </div>

        @* ── Material breakdown table ────────────────────────────── *@
        <div class="section-card">
            <div class="section-head">
                <h2><i class="fa fa-recycle fa-sm"></i> Recycling by Material — @Model.MonthLabel</h2>
            </div>
            <table class="rep-table">
                <thead>
                    <tr>
                        <th>Material</th>
                        <th>Weight (kg)</th>
                        <th>CO₂ Saved (kg)</th>
                        <th>Points Awarded</th>
                        <th>Submissions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.ByMaterial)
                    {
                        <tr>
                            <td><span class="mat-dot" style="background:@row.ColourCode"></span>@row.MaterialName</td>
                            <td>@row.TotalWeightKg.ToString("0.##")</td>
                            <td>@row.TotalCo2Kg.ToString("0.####")</td>
                            <td>@row.TotalPoints.ToString("N0")</td>
                            <td>@row.SubmissionCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* ── Top residents table ─────────────────────────────────── *@
        if (Model.TopResidents.Any())
        {
            <div class="section-card">
                <div class="section-head">
                    <h2><i class="fa fa-ranking-star fa-sm"></i> Top Residents — @Model.MonthLabel</h2>
                </div>
                <table class="rep-table">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Resident</th>
                            <th>Weight (kg)</th>
                            <th>CO₂ (kg)</th>
                            <th>Points</th>
                            <th>Submissions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var row in Model.TopResidents)
                        {
                            <tr>
                                <td><strong style="color:#2d6a4f;">#@rank</strong></td>
                                <td>@row.FullName</td>
                                <td>@row.WeightKg.ToString("0.##")</td>
                                <td>@row.Co2Kg.ToString("0.####")</td>
                                <td>@row.PointsEarned.ToString("N0")</td>
                                <td>@row.Submissions</td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@section scripts {
    <script>
        var matLabels  = @Html.Raw(matLabelsJson);
        var matWeights = @Html.Raw(matWeightsJson);
        var matColours = @Html.Raw(matColoursJson);

        if (document.getElementById('matChart') && matLabels.length > 0) {
            new Chart(document.getElementById('matChart'), {
                type: 'doughnut',
                data: {
                    labels: matLabels,
                    datasets: [{ data: matWeights, backgroundColor: matColours, borderWidth: 2, borderColor: '#fff' }]
                },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
        }

        if (document.getElementById('ptsChart') && matLabels.length > 0) {
            new Chart(document.getElementById('ptsChart'), {
                type: 'bar',
                data: {
                    labels: matLabels,
                    datasets: [{
                        label: 'Points',
                        data: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ByMaterial.Select(x => x.TotalPoints).ToList())),
                        backgroundColor: matColours,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#f0f0f0' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }
    </script>
}