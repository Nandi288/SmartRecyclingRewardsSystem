@model SmartRecyclingRewardsSystem.Controllers.ImpactViewModel
@{
    ViewBag.Title = "My Environmental Impact";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var matLabels = Model.ByMaterial.Select(x => x.MaterialName).ToList();
    var matWeights = Model.ByMaterial.Select(x => x.TotalWeightKg).ToList();
    var monLabels = Model.ByMonth.Select(x => x.MonthLabel).ToList();
    var monWeights = Model.ByMonth.Select(x => x.WeightKg).ToList();

    string matLabelsJson = Newtonsoft.Json.JsonConvert.SerializeObject(matLabels);
    string matWeightsJson = Newtonsoft.Json.JsonConvert.SerializeObject(matWeights);
    string monLabelsJson = Newtonsoft.Json.JsonConvert.SerializeObject(monLabels);
    string monWeightsJson = Newtonsoft.Json.JsonConvert.SerializeObject(monWeights);

    var matColours = Model.ByMaterial.Select(x => x.ColourCode).ToList();
    string matColoursJson = Newtonsoft.Json.JsonConvert.SerializeObject(matColours);
}

@section styles {
    <style>
        .impact-wrap {
            max-width: 1100px;
            margin: 0 auto;
            padding: 32px 20px 60px;
        }

        .page-banner {
            background: linear-gradient(135deg, #1a3a2a 0%, #2d6a4f 100%);
            border-radius: 14px;
            padding: 32px 36px;
            margin-bottom: 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .page-banner h1 {
                font-family: 'Syne',sans-serif;
                font-size: 26px;
                font-weight: 800;
                color: #fff;
                margin-bottom: 4px;
            }

            .page-banner p {
                color: rgba(255,255,255,0.6);
                font-size: 14px;
                margin: 0;
            }

        .banner-icon {
            width: 64px;
            height: 64px;
            background: rgba(183,224,74,0.2);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: #b7e04a;
            flex-shrink: 0;
        }

        .stats-row {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.07);
            border-radius: 12px;
            padding: 20px;
        }

        .stat-icon {
            float: right;
            width: 38px;
            height: 38px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
        }

        .icon-lime {
            background: #f3fcd4;
            color: #5a7a00;
        }

        .icon-green {
            background: #edf7f1;
            color: #2d6a4f;
        }

        .icon-blue {
            background: #e8f4fd;
            color: #1a6fa8;
        }

        .icon-amber {
            background: #fef9c3;
            color: #92620a;
        }

        .stat-label {
            font-size: 12px;
            font-weight: 600;
            color: #6b7c6e;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .stat-value {
            font-family: 'Syne',sans-serif;
            font-size: 26px;
            font-weight: 800;
            color: #1a3a2a;
            line-height: 1;
        }

        .stat-sub {
            font-size: 12px;
            color: #6b7c6e;
            margin-top: 4px;
        }

        .equiv-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }

        .equiv-card {
            background: #1a3a2a;
            border-radius: 12px;
            padding: 22px 24px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .equiv-icon {
            font-size: 32px;
            flex-shrink: 0;
        }

        .equiv-num {
            font-family: 'Syne',sans-serif;
            font-size: 28px;
            font-weight: 800;
            color: #b7e04a;
            line-height: 1;
        }

        .equiv-desc {
            font-size: 12px;
            color: rgba(255,255,255,0.6);
            margin-top: 4px;
        }

        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }

        .section-card {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.07);
            border-radius: 12px;
            overflow: hidden;
        }

        .section-head {
            padding: 16px 20px;
            border-bottom: 1px solid #f0f0f0;
        }

            .section-head h2 {
                font-family: 'Syne',sans-serif;
                font-size: 15px;
                font-weight: 700;
                color: #1a3a2a;
                margin: 0;
            }

        .chart-wrap {
            padding: 20px;
        }

        .mat-table {
            width: 100%;
            border-collapse: collapse;
        }

            .mat-table th {
                background: #f8fdf9;
                font-size: 11px;
                font-weight: 700;
                color: #6b7c6e;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                padding: 10px 16px;
                text-align: left;
                border-bottom: 1px solid #f0f0f0;
            }

            .mat-table td {
                padding: 12px 16px;
                font-size: 13px;
                color: #111c16;
                border-bottom: 1px solid #f7f7f7;
            }

            .mat-table tr:last-child td {
                border-bottom: none;
            }

        .mat-dot {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 8px;
        }

        .rank-badge {
            background: #1a3a2a;
            color: #b7e04a;
            font-family: 'Syne',sans-serif;
            font-size: 20px;
            font-weight: 800;
            padding: 8px 18px;
            border-radius: 20px;
            display: inline-block;
        }

        .empty-state {
            text-align: center;
            padding: 48px 16px;
            color: #6b7c6e;
        }

            .empty-state i {
                font-size: 40px;
                color: #74c69d;
                margin-bottom: 12px;
                display: block;
            }

        @@media(max-width:768px) {
            .stats-row {
                grid-template-columns: repeat(2,1fr);
            }

            .equiv-row, .charts-row {
                grid-template-columns: 1fr;
            }

            .page-banner {
                flex-direction: column;
                gap: 16px;
                text-align: center;
            }
        }
    </style>
}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<div class="impact-wrap">

    @* ── Page banner ──────────────────────────────────────────── *@
    <div class="page-banner">
        <div>
            <h1>My Environmental Impact</h1>
            <p>See the real-world difference your recycling is making, @Model.User.FirstName.</p>
        </div>
        <div class="banner-icon"><i class="fa fa-leaf"></i></div>
    </div>

    @if (Model.TotalSubmissions == 0)
    {
        <div class="section-card">
            <div class="empty-state">
                <i class="fa fa-recycle"></i>
                <strong>No verified submissions yet.</strong>
                <p style="margin-top:8px;">Once a Collection Officer verifies your recycling, your impact will show here.</p>
                <a href="@Url.Action("Create","RecyclingSubmission")" class="btn-srr" style="margin-top:16px;">
                    <i class="fa fa-plus"></i> Log Your First Submission
                </a>
            </div>
        </div>
    }
    else
    {
        @* ── Stat cards ────────────────────────────────────────── *@
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon icon-green"><i class="fa fa-weight-hanging"></i></div>
                <div class="stat-label">Total Recycled</div>
                <div class="stat-value">@string.Format("{0:0.#}", Model.TotalWeightKg)<small style="font-size:14px"> kg</small></div>
                <div class="stat-sub">across all materials</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-blue"><i class="fa fa-cloud"></i></div>
                <div class="stat-label">CO₂ Saved</div>
                <div class="stat-value">@string.Format("{0:0.##}", Model.TotalCo2Kg)<small style="font-size:14px"> kg</small></div>
                <div class="stat-sub">equivalent CO₂ offset</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-lime"><i class="fa fa-star"></i></div>
                <div class="stat-label">Points Earned</div>
                <div class="stat-value">@Model.TotalPoints.ToString("N0")</div>
                <div class="stat-sub">from recycling activity</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-amber"><i class="fa fa-ranking-star"></i></div>
                <div class="stat-label">Leaderboard Rank</div>
                <div class="stat-value">#@Model.LeaderboardRank</div>
                <div class="stat-sub">@Model.TotalSubmissions verified submission(s)</div>
            </div>
        </div>

        @* ── CO2 Equivalents ────────────────────────────────────── *@
        <div class="equiv-row">
            <div class="equiv-card">
                <span class="equiv-icon">🚗</span>
                <div>
                    <div class="equiv-num">@Model.CarKmEquivalent km</div>
                    <div class="equiv-desc">equivalent to keeping a car off the road for @Model.CarKmEquivalent km</div>
                </div>
            </div>
            <div class="equiv-card">
                <span class="equiv-icon">🌳</span>
                <div>
                    <div class="equiv-num">@Model.TreesEquivalent trees</div>
                    <div class="equiv-desc">equivalent to @Model.TreesEquivalent trees absorbing CO₂ for a full year</div>
                </div>
            </div>
        </div>

        @* ── Charts ─────────────────────────────────────────────── *@
        <div class="charts-row">
            <div class="section-card">
                <div class="section-head">
                    <h2><i class="fa fa-chart-pie fa-sm"></i> Weight by Material Type</h2>
                </div>
                <div class="chart-wrap">
                    <canvas id="matChart" height="220"></canvas>
                </div>
            </div>
            <div class="section-card">
                <div class="section-head">
                    <h2><i class="fa fa-chart-line fa-sm"></i> Monthly Recycling (last 12 months)</h2>
                </div>
                <div class="chart-wrap">
                    <canvas id="monChart" height="220"></canvas>
                </div>
            </div>
        </div>

        @* ── Material breakdown table ───────────────────────────── *@
        <div class="section-card">
            <div class="section-head">
                <h2><i class="fa fa-table fa-sm"></i> Breakdown by Material</h2>
            </div>
            <table class="mat-table">
                <thead>
                    <tr>
                        <th>Material</th>
                        <th>Weight (kg)</th>
                        <th>CO₂ Saved (kg)</th>
                        <th>Points Earned</th>
                        <th>Submissions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.ByMaterial)
                    {
                        <tr>
                            <td>
                                <span class="mat-dot" style="background:@row.ColourCode"></span>
                                @row.MaterialName
                            </td>
                            <td>@row.TotalWeightKg.ToString("0.##")</td>
                            <td>@row.TotalCo2Kg.ToString("0.####")</td>
                            <td>@row.TotalPoints.ToString("N0")</td>
                            <td>@row.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section scripts {
    <script>
    var matLabels  = @Html.Raw(matLabelsJson);
    var matWeights = @Html.Raw(matWeightsJson);
    var matColours = @Html.Raw(matColoursJson);
    var monLabels  = @Html.Raw(monLabelsJson);
    var monWeights = @Html.Raw(monWeightsJson);

    if (document.getElementById('matChart')) {
        new Chart(document.getElementById('matChart'), {
            type: 'doughnut',
            data: {
                labels: matLabels,
                datasets: [{ data: matWeights, backgroundColor: matColours, borderWidth: 2, borderColor: '#fff' }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });
    }

    if (document.getElementById('monChart')) {
        new Chart(document.getElementById('monChart'), {
            type: 'bar',
            data: {
                labels: monLabels,
                datasets: [{
                    label: 'kg recycled',
                    data: monWeights,
                    backgroundColor: 'rgba(45,106,79,0.7)',
                    borderColor: '#2d6a4f',
                    borderWidth: 1,
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f0f0f0' } },
                    x: { grid: { display: false } }
                }
            }
        });
    }
    </script>
}
