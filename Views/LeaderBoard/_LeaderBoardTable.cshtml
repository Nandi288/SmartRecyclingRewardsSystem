@model System.Collections.Generic.List<SmartRecyclingRewardsSystem.ViewModels.CommunityLeaderboardViewModel>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Rank</th>
            <th>Name</th>
            <th>Points</th>
            <th>Weight (kg)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var row in Model)
        {
            <tr class="@(row.IsCurrentUser ? "leaderboard-highlight" : "")">
                <td>@row.Rank</td>
                <td>@row.FirstName @row.LastName</td>
                <td>@row.TotalPoints</td>
                <td>@row.TotalRecycledkg.ToString("F1")</td>
            </tr>
        }
    </tbody>
</table>